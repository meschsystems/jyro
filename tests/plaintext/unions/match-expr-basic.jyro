# Test match expression in variable assignment

union Shape
    Circle(radius: number)
    Rect(width: number, height: number)
end

func Area(shape)
    return match shape do
        case Circle(r) then 3.14159 * r * r
        case Rect(w, h) then w * h
    end
end

Data.circleArea = Area(Circle(10))
Data.rectArea = Area(Rect(3, 4))
